{
	"name": "nn-airchecker",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"calibrate": "tsx src/tools/calibrate.ts",
		"probe": "node --env-file-if-exists=.env --import tsx src/tools/probeFrame.ts",
		"capture-golden": "node --env-file-if-exists=.env --import tsx src/tools/captureGolden.ts",
		"verify": "node --env-file-if-exists=.env --import tsx src/tools/verifyExtraction.ts",
		"measure-call": "node --env-file-if-exists=.env --import tsx src/tools/measureCall.ts",
		"chrome:debug": "'/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' --remote-debugging-port=9222 --user-data-dir=$HOME/.nn-airchecker-chrome --window-size=960,540 --window-position=0,0 https://stream.directv.com/player",
		"air:probe": "node --env-file-if-exists=.env --import tsx src/tools/airProbe.ts",
		"live": "node --env-file-if-exists=.env --import tsx src/runtime/liveMain.ts",
		"web:build": "cd src/web/client && npm install && npm run build",
		"web:dev": "cd src/web/client && npm run dev"
	},
	"devDependencies": {
		"@eslint-react/eslint-plugin": "^5.8.5",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.10.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-perfectionist": "^5.9.0",
		"eslint-plugin-prettier": "^5.5.5",
		"prettier": "^3.8.3",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0",
		"typescript-eslint": "^8.60.0",
		"vitest": "^2.1.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.100.1",
		"@fastify/static": "^9.1.3",
		"better-sqlite3": "^12.10.0",
		"fastify": "^5.8.5",
		"puppeteer-core": "^25.1.0",
		"sharp": "^0.34.5",
		"zod": "^4.4.3"
	}
}
